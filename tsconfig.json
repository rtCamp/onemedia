{
	"$schema": "https://json.schemastore.org/tsconfig.json",
	"extends": "./tsconfig.base",
	"compilerOptions": {
		"noEmit": true,
		"rootDir": ".",
		"baseUrl": "./assets/src",
		"outDir": "./build"
	},
	"include": ["**/*.d.ts", "**/*.mjs", "**/*.ts", "**/*.tsx", "**/*.json"],
	"exclude": ["**/build/*", "vendor/*", "node_modules/*"]
}
